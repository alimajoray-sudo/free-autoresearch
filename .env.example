# Required: At least one FREE provider key
HF_TOKEN=hf_your-token-here                   # Free Inference API (Qwen 72B, Llama 70B, Mixtral)
OPENROUTER_API_KEY=sk-or-v1-your-key-here    # Free :free models
NVIDIA_API_KEY=nvapi-your-key-here            # Free NIM credits

# Optional: Paid providers (uncomment in router.py MODEL_POOL to enable)
# XAI_API_KEY=xai-your-key-here              # ~$0.0003/call
# DEEPSEEK_API_KEY=sk-your-key-here          # ~$0.0004/call

# Optional: Budget cap (USD/day, default 0.50 — only matters if paid providers enabled)
AUTORESEARCH_DAILY_BUDGET=0.50
